{
  "name": "stx-vault-sdk",
  "version": "1.0.2",
  "description": "Production SDK for STX vault and time-lock applcaton the Stacks blockchain, with CLI, React hooks, analytics, and wallet support.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "stacks",
    "stx",
    "vault",
    "defi",
    "web3",
    "time-lock",
    "stacks-sdk",
    "cli",
    "react-hook",
    "analytics"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/investorphem/stx-vault-sdk"
  },
  "author": "Oluwafemi Olagoke",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/cli.ts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@stacks/connect": "^7.0.1",
    "@stacks/network": "^7.0.1",
    "@stacks/transactions": "^7.0.1",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^7.2.0",
    "typescript": "^5.3.3"
  },
  "bin": {
    "stx-vault": "./dist/cli.js"
  }
}